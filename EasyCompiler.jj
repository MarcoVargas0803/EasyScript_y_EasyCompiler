
options {
  IGNORE_CASE = false; // EasyScript distingue entre mayГәsculas y minГәsculas para sus variables y Constantes.
  STATIC = false;
}

//Inicia el parser. 
PARSER_BEGIN(EasyCompiler)

import java.util.ArrayList;  // Agregado para usar listas dinГЎmicas
import java.util.List;       // Agregado para usar listas dinГЎmicas


public class EasyCompiler {
  // Declaramos la lista de forma estГЎtica para que la clase Main pueda imprimirla al final
    public static List<ErrorCompilador> listaErrores = new ArrayList<>();
}

PARSER_END(EasyCompiler)


/*
DefiniciГіn de la lГ©xica de EasyCompiler

*/

SKIP : {
  " " | "\t" | "\n" | "\r"
  | < COMENTARIO_LINEA: "//" (~["\n","\r"])* ("\n"|"\r"|"\r\n") > // Ignora todo despuГ©s de // hasta el salto de lГӯnea.
  | < COMENTARIO_BLOQUE: "/*" (~["*"])* "*" (~["/"] (~["*"])* "*")* "/" > // Ignora lo que estГ© entre /* y */ 

  //Captura de errores lexicos
  //image.toString() : guarda el texto que hizo match.
  //input_stream.getEndLine() : obtiene la lГӯnea exacta del error cuando estamos dentro de un SKIP.

  // 1. Cadena no cerrada con comillas dobles
  // Abre comillas, lee cualquier cosa que no sea cerrar comillas ni salto de lГӯnea.
  < ERROR_TEXTO: "\"" (~["\"","\n","\r"])* >
  {
      // AcciГіn LГ©xica: Esto se ejecuta al instante
    EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Cadena de texto sin cerrar.",
                            "Cierra la cadena de texto con comillas dobles."));
    }

  // 2. CarГЎcter no cerrado con comillas simples
| < ERROR_CARACTER: "'" (~["'","\n","\r"])* >
  {
        // AcciГіn LГ©xica: Esto se ejecuta al instante
      EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Caracter sin cerrar.",
                            "Cierra el caracter con comillas simples."));
    }

  // 3. Formato de nГәmero decimal invГЎlido
  // Atrapa nГәmeros con mГәltiples puntos decimales, ej. 3.14.15.
| < ERROR_NUMERO_INVALIDO: (["0"-"9"])+ "." (["0"-"9"])+ ("." (["0"-"9"])+)+ >
  {
        // AcciГіn LГ©xica: Esto se ejecuta al instante
        EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Formato decimal invalido '" + token.image + "'",
                            "Sigue la regla para decimales. Ejemplo: 3.1416"));
    }

  // 4. Identificador invГЎlido
  // Atrapa identificadores que comienzan con nГәmero. ejemplo 9numero.
  // O que comienzan con minГәscula. ejemplo: numero.
  // O que tengan mГЎs de una letra en mayuscula. ejemplo: PrimerNumero.  

| < ERROR_IDENTIFICADOR_INVALIDO: 
      ( ["0"-"9"] (["a"-"z", "A"-"Z", "0"-"9", "_", "ГЎ","Г©","Гӯ","Гі","Гә","ГҒ","Гү","ГҚ","Г“","Гҡ","Гұ","Г‘"])+ ) 
    | ( ["a"-"z", "ГЎ","Г©","Гӯ","Гі","Гә","Гұ"] (["a"-"z", "A"-"Z", "0"-"9", "_", "ГЎ","Г©","Гӯ","Гі","Гә","ГҒ","Гү","ГҚ","Г“","Гҡ","Гұ","Г‘"])* ) 
    | ( ["A"-"Z", "ГҒ","Гү","ГҚ","Г“","Гҡ","Г‘"] (["a"-"z", "0"-"9", "_", "ГЎ","Г©","Гӯ","Гі","Гә","Гұ"])* ["A"-"Z", "ГҒ","Гү","ГҚ","Г“","Гҡ","Г‘"] (["a"-"z", "A"-"Z", "0"-"9", "_", "ГЎ","Г©","Гӯ","Гі","Гә","ГҒ","Гү","ГҚ","Г“","Гҡ","Гұ","Г‘"])* ) 
  >
  {
        // AcciГіn LГ©xica: Esto se ejecuta al instante
        EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Identificador no valido '" + token.image + "'",
                            "Toda variable/constante debe iniciar con mayuscula."));
    }

  // 5. CarГЎcter con longitud invalida o caracter no definido
  // Atrapa textos encerrados en comillas simples que tienen mГЎs de una letra (ej. 'Numero') o ninguna ('') o que no son definidas como $, #.
| < ERROR_LONGITUD_CARACTER: "'" (~["'","\n","\r"])* "'" >
  {
        // AcciГіn LГ©xica: Esto se ejecuta al instante
        EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Formato de caracter invalido: " + token.image,
                            "Longitud mayor a 1 o caracter no reconocido para LETRA."));
    }

  // 6. Operadores lГіgicos incompletos o mal escritos
  // Atrapa sГӯmbolos que deberГӯan ir dobles en EasyScript pero se escribieron solos.
| < ERROR_OPERADOR_INCOMPLETO: "!" | "&" | "|" >
  {
        // AcciГіn LГ©xica: Esto se ejecuta al instante
        EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Operador incompleto o no valido: '" + token.image + "'",
                            "Los operadores en EasyScript son dobles (&&, ||, !!)."));
    }

  // 7. SГӯmbolo no vГЎlido en el lenguaje
  // Este es el comodГӯn definitivo. El sГӯmbolo "~[]" significa "cualquier carГЎcter". 
  // Como estГЎ al final de todo, atraparГЎ sГӯmbolos raros como @ o # que no encajaron en NINGUNA regla anterior.
| < ERROR_SIMBOLO: ~[] >
  {
        // AcciГіn LГ©xica: Esto se ejecuta al instante
        EasyCompiler.listaErrores.add(new ErrorCompilador(ErrorLexicoTipo, token.beginLine, token.beginColumn,
                            "Simbolo no valido '" + token.image + "'",
                            "Usa la simbologia definida en el manual de usuario."));
    }

}

//Palabras/Simbolos Reservados

TOKEN : {
  // Flujo del programa 
  < INICIO_PROGRAMA: "INICIO" > 
| < FIN_PROGRAMA: "FIN" > 

  // Tipos de datos y estructuras de datos 
| < ENTERO_DATO: "ENT" > 
| < DECIMAL_DATO: "DEC" > 
| < BOOLEANO_DATO: "BOOL" > 
| < CARACTER_DATO: "LETRA" > 
| < TEXTO_DATO: "TXT" > 
| < ARREGLO_ESTRUCTURA: "ARREGLO" >
| < MATRIZ_ESTRUCTURA: "MATRIZ" > 

  //Booleanos
| <VERDADERO_BOOLEANO: "VERDADERO">
| <FALSO_BOOLEANO: "FALSO">

  // Condicionales y Ciclos 
| < SI_CONDICIONAL: "SI" > 
| < SI_CONTRARIO: "CONTRARIO" > 
| < SI_SINO: "SINO" >
| < SEGUN_CONDICIONAL: "SEGUN" >    
| < CASO_SEGUN: "CASO" >       
| < DEFECTO_SEGUN: "DEFECTO" > 
| < DETENER_SEGUN: "DETENER" >
| < PARA_CICLO: "PARA" > 
| < MIENTRAS_CICLO: "MIENTRAS" >

  // Entrada y Salida
| < LEER_FUNCION: "LEER" >
| < IMPRIMIR_FUNCION: "IMPRIMIR" > 
}

// Operadores reservados y delimitadores 

TOKEN : {
  // Operadores de Incremento y Decremento
  < INCREMENTO_AL_VALOR: "++" > 
| < DECREMENTO_AL_VALOR: "--" > 

  // Operadores AritmГ©ticos
| < SUMA: "+" > 
| < RESTA: "-" >
| < MULTIPLICACION: "*" > 
| < DIVISION: "/" >

  // Operadores Adicionales
| < MODULO: "%" > 
| < EXPONENTE: "**" >

// Operadores de comparaciГіn
| < IGUAL_ASIGNACION: "=" > 
| < IGUAL_COMPARACION: "==" >
| < DIFERENTE: "!=" > 
| < MENOR: "<" >
| < MENOR_IGUAL: "<=" >
| < MAYOR: ">" >
| < MAYOR_IGUAL: ">=" >

// Operadores LГіgicos
| < Y_LOGICO: "&&" > 
| < O_LOGICO: "||" >
| < NO_LOGICO: "!!" > 

  // Delimitadores 
| < ABRIR_LLAVE: "{" > 
| < CERRAR_LLAVE: "}" > 
| < ABRIR_PARENTESIS: "(" > 
| < CERRAR_PARENTESIS: ")" > 
| < ABRIR_CORCHETE: "[" > 
| < CERRAR_CORCHETE: "]" >  
| < COMA: "," >
| < DOS_PUNTOS: ":" >
| < PUNTO_COMA: ";" > 
}

// Expresiones Regulares para Variables, Constantes, Cadenas y Caracteres. 

TOKEN : {

  // Variables: Inician con mayГәscula, y el resto ESTRICTAMENTE minГәsculas, nГәmeros o guion bajo
  < VARIABLE: ["A"-"Z", "ГҒ","Гү","ГҚ","Г“","Гҡ","Г‘"] (["a"-"z", "0"-"9", "_", "ГЎ","Г©","Гӯ","Гі","Гә","Гұ"])* >

  // Constantes: Inician con CONST_ seguido de la estructura de variable
| < CONSTANTE: "CONST_" ["A"-"Z", "ГҒ","Гү","ГҚ","Г“","Гҡ","Г‘"] (["a"-"z", "0"-"9", "_", "ГЎ","Г©","Гӯ","Гі","Гә","Гұ"])* >
  
  // NГәmeros: Enteros y Decimales
| < NUM_ENTERO: (["0"-"9"])+ >
| < NUM_DECIMAL: ( (["0"-"9"])+ "." (["0"-"9"])+ ) | ( "." (["0"-"9"])+ ) >


  // Cadenas de texto: Todo lo que estГ© entre comillas dobles
| < CADENA: "\"" ( 
      (~["\"","\\","\n","\r"]) // Acepta cualquier carГЎcter normal excepto comillas, barras invertidas o saltos de lГӯnea fГӯsicos.
      | ("\\" ["n","t","r","\\","\""]) // <-- O acepta secuencias de escape.
  )* "\"" >

|  < VALOR_LETRA: "'" ["a"-"z", "A"-"Z", "0"-"9"] "'" >

}

// Tokens de Error

TOKEN : {
  
}

/*
  AnГЎlisis Sintactico
*/
// Sentencias adentro del los Tokens INICIO Y FIN.
void Sentencias() :
{}
{
    (
        DeclaracionVariable()
      | Imprimir()
      | Leer()
      | CondicionalSi()
      | CondicionalSegun()
      | BuclePara()
    )*
}

void Programa() :
{}
{
  try{
    <INICIO_PROGRAMA> 
    <ABRIR_LLAVE>
    
    Sentencias() // <-- ВЎLlamamos a las sentencias aquГӯ!
    
    <CERRAR_LLAVE> 
    <FIN_PROGRAMA> 
    <EOF>
  }catch(ParseException e){
    listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "Estructura principal malformada.", 
            "Todo cГіdigo debe comenzar con INICIO { y terminar con } FIN."));
            
        // Como es la regla raГӯz, si falla gravemente, consumimos hasta el final del archivo
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != EOF);
  }
    
}

// Regla que agrupa los tipos de datos de EasyScript

void TipoDato() :
{}
{
    <ENTERO_DATO> | <DECIMAL_DATO> | <BOOLEANO_DATO> | <CARACTER_DATO> | <TEXTO_DATO>
}

// Regla para los valores que puede tomar una variable
void Valor() :
{}
{
    <NUM_ENTERO> 
  | <NUM_DECIMAL> 
  | <CADENA> // Asumiendo que asГӯ llamaste al token de textos entre comillas dobles
  | <VALOR_LETRA> // El token de caracteres entre comillas simples
  | <VERDADERO_BOOLEANO> 
  | <FALSO_BOOLEANO> 
  | <VARIABLE>
  | <CONSTANTE>
}

// Regla principal para declarar variables
void DeclaracionVariable() :
{}
{
    try {
        TipoDato() 
        <VARIABLE> 
        ( <IGUAL_ASIGNACION> Valor() )? 
        <PUNTO_COMA>  // Si falta esto, salta al catch
    } catch (ParseException e) {
        // Agregamos a la tabla de errores
        listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "Falta el delimitador final de la sentencia ( ; ).", 
            "Asegurate de terminar la declaracion de tu variable con un punto y coma."));
            
        // Se traga los tokens basura hasta encontrar el siguiente punto y coma para seguir compilando
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != PUNTO_COMA && t.kind != EOF);
    }
}

/*
  Gramatica para la impresiГіn
*/ 

// Regla para lo que va dentro del IMPRIMIR ("texto" + variable)
void ExpresionImprimir() :
{}
{
    Valor() ( <SUMA> Valor() )*
}

// ==========================================
// ENTRADA Y SALIDA (Con recuperaciГіn de errores)
// ==========================================

void Imprimir() :
{}
{
    try {
        <IMPRIMIR_FUNCION> <ABRIR_PARENTESIS> ExpresionImprimir() <CERRAR_PARENTESIS> <PUNTO_COMA>
    } catch (ParseException e) {
        // 1. Guardamos el error en la tabla
        listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "Sintaxis incorrecta en IMPRIMIR.", 
            "AsegГәrate de usar la estructura IMPRIMIR(valor);"));
            
        // 2. RecuperaciГіn: Consumimos tokens basura hasta encontrar el punto y coma
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != PUNTO_COMA && t.kind != EOF);
    }
}

void Leer() :
{}
{
    try {
        <LEER_FUNCION> <ABRIR_PARENTESIS> <VARIABLE> <CERRAR_PARENTESIS> <PUNTO_COMA>
    } catch (ParseException e) {
        listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "Sintaxis incorrecta en LEER.", 
            "La estructura correcta es LEER(Variable);"));
            
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != PUNTO_COMA && t.kind != EOF);
    }
}

// Operadores Relacionales (Asume que tienes estos tokens definidos)
void OperadorRelacional() :
{}
{
    <MAYOR> | <MENOR> | <IGUAL_COMPARACION> | <DIFERENTE> | <MAYOR_IGUAL> | <MENOR_IGUAL>
}

// Una condiciГіn simple: Variable > 5
void Condicion() :
{}
{
    Valor() OperadorRelacional() Valor()
    // AquГӯ puedes expandirlo para incluir AND (&&) y OR (||) si tu lenguaje lo permite
}

// ==========================================
// CONDICIONAL SI / CONTRARIO / SINO
// ==========================================
void CondicionalSi() :
{}
{
    try{
      <SI_CONDICIONAL> <ABRIR_PARENTESIS> Condicion() <CERRAR_PARENTESIS> <ABRIR_LLAVE> 
              Sentencias() 
           <CERRAR_LLAVE>
          
      // El CONTRARIO (Else If) es opcional y puede repetirse (*)
          (
              <SI_CONTRARIO> <ABRIR_PARENTESIS> Condicion() <CERRAR_PARENTESIS> <ABRIR_LLAVE> 
                  Sentencias() 
              <CERRAR_LLAVE>
          )*
          
          // El SINO (Else) es opcional y solo aparece una vez (?)
          (
              <SI_SINO> <ABRIR_LLAVE> 
                  Sentencias() 
              <CERRAR_LLAVE>
          )?
    }catch(ParseException e){
          // Agregamos el error a la tabla
        listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "CondiciГіn ausente, malformada o bloque sin llaves en SI.", 
            "Verifica que la condiciГіn lГіgica estГ© completa y encierra las sentencias entre { }."));
            
        // RecuperaciГіn de pГЎnico: Buscar la llave de cierre para salir del bloque roto
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != CERRAR_LLAVE && t.kind != EOF);

    }
    
}

// ==========================================
// CONDICIONAL SEGUN (Switch)
// ==========================================
void CondicionalSegun() :
{}
{
    try{
    <SEGUN_CONDICIONAL> <ABRIR_PARENTESIS> <VARIABLE> <CERRAR_PARENTESIS> <ABRIR_LLAVE>
            
            // Debe haber al menos un CASO (+)
            (
                <CASO_SEGUN> Valor() <DOS_PUNTOS> 
                    Sentencias() 
                <DETENER_SEGUN> <PUNTO_COMA>
            )+
            
            // El DEFECTO es opcional (?)
            (
                <DEFECTO_SEGUN> <DOS_PUNTOS> 
                    Sentencias()
            )?
        
    <CERRAR_LLAVE>

    }catch(ParseException e){
            listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "Estructura SEGUN incompleta o sintaxis invГЎlida.", 
            "El SEGUN requiere 'CASO valor:', finalizar cada caso con 'DETENER;' y cerrar llaves."));
            
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != CERRAR_LLAVE && t.kind != EOF);

    }
    
}

// ==========================================
// BUCLE PARA
// ==========================================
void BuclePara() :
{}
{
  try{
    <PARA_CICLO> <ABRIR_PARENTESIS> 
          // 1. DeclaraciГіn inicial (Ej. ENT i = 0;)
          DeclaracionVariable() 
          
          // 2. CondiciГіn (Ej. i < 10)
          Condicion() <PUNTO_COMA>
          
          // 3. Incremento/Decremento (Asumiendo tokens como INCREMENTO para "++")
          <VARIABLE> ( <INCREMENTO_AL_VALOR> | <DECREMENTO_AL_VALOR> )
          
    <CERRAR_PARENTESIS> <ABRIR_LLAVE>
          Sentencias()
    <CERRAR_LLAVE>
  }catch(ParseException e){
    listaErrores.add(new ErrorCompilador("SintГЎctico", e.currentToken.next.beginLine, e.currentToken.next.beginColumn, 
            "ParГЎmetros incompletos o invГЎlidos en el ciclo PARA.", 
            "El ciclo necesita 3 partes: DeclaraciГіn ; CondiciГіn ; Incremento/Decremento."));
            
        Token t;
        do {
            t = getNextToken();
        } while (t.kind != CERRAR_LLAVE && t.kind != EOF);
    
  }
   
}